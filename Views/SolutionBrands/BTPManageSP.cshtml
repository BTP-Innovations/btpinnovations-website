<!--Software Start-->
<section class="all-services">
    <div class="container">
        <div class="row">
            <div class="col-xl-4 col-lg-4">
                <div class="pq-widget">
                    <div class="pq-widget pq-widget-port p-0">
                        <div class="menu-service-menu-container">
                            <ul id="menu-service-menu" class="menu">
                                <li @*class="current-menu-item"*@>
                                    <a href="~/SolutionBrands/BTPCodeIGNITE" aria-current="page" style="text-transform:none;">BTP CodeIGNITE</a>
                                </li>

                                <li>
                                    <a href="~/SolutionBrands/BTPSecuriSCOPE" aria-current="page" style="text-transform:none;">BTP SecuriSCOPE</a>
                                </li>

                                <li>
                                    <a href="~/SolutionBrands/BTPCloudEXCELON" aria-current="page" style="text-transform:none;">BTP CloudEXCELON</a>
                                </li>

                                <li>
                                    <a href="~/SolutionBrands/BTPConnect" aria-current="page" style="text-transform:none;">BTP Connect</a>
                                </li>

                                <li class="current-menu-item">
                                    <a href="~/SolutionBrands/BTPManageSP" aria-current="page" style="text-transform:none;">BTP ManageSP</a>
                                </li>
                                <li>
                                    <a href="~/SolutionBrands/BTPDatastAIsis" aria-current="page" style="text-transform:none;">BTP DatastAIsis</a>
                                </li>
                                <li>
                                    <a href="~/SolutionBrands/BTPTechAdvisors" aria-current="page" style="text-transform:none;">BTP TechAdvisors</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="media-image">
                    <div class="pq-form-section pq-style-1" style="position:absolute;padding-left:10px;padding-top:10px;">
                        <span class="pq-form-title" style="font-size: 22px; line-height: 10px; font-weight: 900 ">Have an Idea?</span><br />
                        <span class="pq-form-title" style="font-size: 22px; line-height: 10px; font-weight: 900">We can help</span>
                    </div>
                    <a href="#"><img src="~/Content/WebsiteContent/images/callcenter.jpg" alt=""></a>
                </div>
            </div>
            <div class="col-xl-8 col-lg-8 mt-4 mt-lg-0" @*style="padding-right: 149px;"*@>
                <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_main.png" alt="">
                <h2 class="pq-heading mt-4">
                    Managed IT Operations & Support
                </h2>
                <p class="pq-description">
                     BTP ManageSP delivers proactive monitoring, system management, and operational 
                     support to keep your technology environment running smoothly. Our team helps 
                     reduce downtime, improve reliability, and scale IT operations with confidence
                </p>
                <div class="row">
                    <div class="col-lg-6 col-md-6 col-sm-12">
                        <div class="pq-fancy-box pq-fancybox-1">
                            <div class="pq-fancy-media" style="width: 164px;height: 100px;margin: -63px;margin-top: -14px; margin-right: -32px; mix-blend-mode: multiply;" >
                                <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_mon_icon.png" />
                            </div>
                            <div class="pq-fancybox-info">
                                <h5 class="pq-fancy-box-title">24/7 Monitoring</h5>
                                <p>
                                     Continuous monitoring of infrastructure, networks, and systems to detect 
                                     issues early, prevent outages, and maintain operational stability across 
                                     your IT environment.
                                </p>

                            </div>
                        </div>
                        <div class="pq-fancy-box pq-fancybox-1 pq-mt-30 mb-4">
                            <div class="pq-fancy-media" style="width: 164px;height: 100px;margin: -63px;margin-top: -14px; margin-right: -32px;" >
                                <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_sd_icon.png" />
                            </div>
                            <div class="pq-fancybox-info">
                                <h5 class="pq-fancy-box-title">Service Desk Support</h5>
                                <p>
                                     Responsive help desk and technical support services to assist 
                                     your team with IT issues, system access, and day-to-day operational needs.
                                </p>

                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 mt-4 mt-md-0">
                        <div class="pq-fancy-box pq-fancybox-1 pq-ml-30">
                            <div class="pq-fancy-media" style="width: 164px;height: 100px;margin: -63px;margin-top: -14px; margin-right: -32px;" >
                                <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_infra_icon.png" />
                            </div>
                            <div class="pq-fancybox-info">
                                <h5 class="pq-fancy-box-title">Managed Infrastructure</h5>
                                <p>
                                     Proactive management of servers, cloud platforms, and core infrastructure 
                                     to ensure performance, reliability, and secure operations across hybrid environments.
                                </p>

                            </div>
                        </div>
                        <div class="pq-fancy-box pq-fancybox-1 pq-mt-30 pq-ml-30 mb-4">
                            <div class="pq-fancy-media" style="width: 164px;height: 100px;margin: -63px;margin-top: -14px; margin-right: -32px;" >
                                <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_at-icon.png" />
                            </div>
                            <div class="pq-fancybox-info">
                                <h5 class="pq-fancy-box-title">Automation & Optimization</h5>
                                <p>
                                     Automation tools and operational improvements designed to streamline IT processes, 
                                     reduce manual workload, and improve service delivery.
                                </p>

                            </div>
                        </div>
                    </div>

                </div>
                <div class="row mt-4 align-items-center border-0">
                    <div class="col-lg-6">
                        <img src="~/Content/WebsiteContent/images/services/blockcentral/managesp_itpro.png" alt="">
                    </div>
                    <div class="col-lg-6">
                        <h2 class="pq-about-title mt-4 mt-lg-0">
                            <a href="#">
                                Reliable IT Operations Partner
                            </a>
                        </h2>
                        <p class="pq-description mb-0">
                             BTP ManageSP acts as an extension of your internal IT team, providing the operational 
                             expertise, monitoring, and support needed to maintain secure and reliable technology environments.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
                <div class="inquiry-form pq-bg-grey">
                    <div class="pq-form-section pq-style-1 ">
                        <span class="pq-form-title" style="font-size:20px;">Call Us Now</span><br />
                        <span class="pq-form-title" style="font-size: 20px; font-weight: 700">(800) 781-6632</span>
                        <h5 class="pq-form-title" style="font-size:24px;line-height:28px;">Request A Free Consultation</h5>
                    </div>
                    @using (Html.BeginForm("BTPManageSP", "SolutionBrands", FormMethod.Post, new { @class = "pq-applyform" }))
                    {
                        <div class="row">
                            <div class="col-md-12">
                                @*<input type="text" id="first-name" class="pq-bg-white name-field" placeholder="Your Name" required>*@
                                @Html.TextBoxFor(m => m.firstName, new { placeholder = "Your Name", @class = "pq-bg-white name-field", required = "required" })
                            </div>
                            <div class="col-md-12">
                                @*<input type="text" id="e-mail" class="pq-bg-white e-mail-field" placeholder="Email" required>*@
                                @Html.TextBoxFor(m => m.email, new { placeholder = "Email", @class = "pq-bg-white e-mail-field", required = "required" })
                            </div>
                            <div class="col-md-12">
                                @*<input type="text" id="phone-number" class="pq-bg-white phone-number-field" placeholder="Cell Phone" required>*@
                                @Html.TextBoxFor(m => m.phoneNumber, new { placeholder = "Phone", @class = "pq-bg-white phone-number-field", required = "required" })
                            </div>
                            <div class="col-md-12">
                                @*<input type="text" id="subject" class="pq-bg-white subject-field" placeholder="Subject" required>*@
                                @Html.TextBoxFor(m => m.Subject, new { placeholder = "Subject", @class = "pq-bg-white subject-field", required = "required" })
                            </div>
                            <div class="col-md-12">
                                @*<textarea name="your-message" id="message" class="pq-bg-white" cols="10" rows="4" placeholder="Your Message" required></textarea>*@
                                @Html.TextAreaFor(m => m.Message, new { rows = "5", cols = "10", placeholder = "Your Message", @class = "pq-bg-white name-field", required = "required" })
                            </div>
                            <div class="col-md-12">
                                <div class="pq-button-block">
                                    <input class="pq-button-text" id="emailForm" type="submit" value="Send Message" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<!--Software End-->
